{
  "name": "narada",
  "version": "1.0.0",
  "description": "Messenger of the Homelab",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/index.js",
    "sms:audit": "tsx src/cli/sms/smsAudit.cli.ts",
    "sms:import": "tsx src/cli/sms/smsImport.cli.ts",
    "sms:extract": "tsx src/cli/sms/smsExtract.cli.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vipulism/narada.git"
  },
  "keywords": [
    "homelab",
    "monitoring",
    "alerts",
    "telegram",
    "docker",
    "home-assistant",
    "observability",
    "nodejs"
  ],
  "author": "Vipul Sharma",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/vipulism/narada/issues"
  },
  "homepage": "https://github.com/vipulism/narada#readme",
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "amqplib": "^2.0.1",
    "axios": "^1.16.1",
    "dockerode": "^5.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.9.3",
    "mysql2": "^3.22.4",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1"
  }
}
