{
    "defaults": {
        "intervalSeconds": 60,
        "timeoutMs": 5000,
        "slowThresholdMs": 2000,
        "notifiers": ["telegram"]
    },
    "services": [
        {
            "name": "PowerCast Health",
            "id": "powercast-health",
            "type": "http",
            "url": "http://192.168.1.32:61209/api/health",
            "critical": true
        },
        {
            "name": "PowerCast Home Assistant",
            "id": "powercast-ha",
            "type": "http",
            "url": "http://192.168.1.32:61209/api/status/home-assistant",
            "critical": true,
            "notifiers":["email"]
        },
        {
            "name": "PowerCast Usage Today",
            "id": "powercast-usage-today",
            "type": "http",
            "url": "http://192.168.1.32:61209/api/usage/today",
            "critical": false,
            "slowThresholdMs": 3000
        }
    ]
}